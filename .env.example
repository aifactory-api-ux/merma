# =============================================================================
# MERMA PROJECT - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your values
# WARNING: Never commit .env to version control!

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=merma

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# JWT CONFIGURATION
# =============================================================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# =============================================================================
# SERVICE PORTS (Internal - DO NOT change for Docker Compose)
# =============================================================================
AUTH_SERVICE_PORT=8001
INVENTORY_SERVICE_PORT=8002
PREDICTION_SERVICE_PORT=8003
RECOMMENDATION_SERVICE_PORT=8004
ALERT_SERVICE_PORT=8005

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
FRONTEND_PORT=3000
REACT_APP_API_URL=http://localhost:8001

# =============================================================================
# NODE ENVIRONMENT
# =============================================================================
NODE_ENV=development
